    "scp": "scp.exe (OpenSSH) or Copy-Item -ToSession (WinRM)",
    "ssh": "ssh.exe (OpenSSH)",
    "tar": "tar.exe (built-in since Win10 1803)",
    "nohup": "Start-Process -NoNewWindow",
    "pgrep": "Get-Process -Name (use with caution — prefer -Id)",
    "pkill": "Stop-Process -Name or taskkill /IM",
    "killall": "taskkill /IM",
    "nice": "Start-Process with priority",
    "renice": "Get-Process | ForEach-Object { $_.PriorityClass = ... }",
    "xargs": "ForEach-Object or pipeline input",
    "sort": "Sort-Object",
    "uniq": "Get-Unique or Sort-Object -Unique",
    "cut": "(-split) or Select-Object -Index",
    "tr": "-replace",
    "basename": "Split-Path -Leaf",
    "dirname": "Split-Path -Parent",
    "readlink": "Get-Item | Select-Object -ExpandProperty Target",
    "realpath": "Resolve-Path",
