    "awk": "PowerShell string operators (-split, -match)",
    "cat": "Get-Content or type",
    "ls -l": "Get-ChildItem",
    "ls -la": "Get-ChildItem -Force",
    "ls -a": "Get-ChildItem -Force",
    "touch": "New-Item",
    "chmod": "icacls",
    "chown": "icacls",
    "sudo": "Start-Process -Verb RunAs",
    "ps aux": "Get-Process",
    "ps -ef": "Get-Process",
    "kill": "Stop-Process -Id or taskkill /PID",
    "kill -9": "taskkill /F /PID",
    "df -h": "Get-PSDrive or Get-Volume",
    "du -sh": "Get-ChildItem -Recurse | Measure-Object -Property Length -Sum",
    "wc -l": "Measure-Object -Line",
    "which": "Get-Command or where",
    "source": ". (dot-source)",
    "ln -s": "New-Item -ItemType SymbolicLink",
    "uname": "[System.Environment]::OSVersion",
    "id": "whoami",
    "pwd": "Get-Location",
    "echo $VAR": "$env:VAR or Write-Output $env:VAR",
    "export VAR=val": "$env:VAR = 'val'",
    "clear": "Clear-Host or cls",
    "history": "Get-History",
    "free -m": "systeminfo or Get-CimInstance Win32_OperatingSystem",
    "tee": "Tee-Object",
    "yes": "while(1){'y'}",
    "seq": "1..N",
    "watch": "while(1){ ... ; Start-Sleep -Seconds N }",
